// File 3 of 3 - the entity store, the ONLY feature shipping now.
//
// Writes/reads the top-level "entities" map:
//
//	entities.<flow>.<entityName> = { value, confidence }
//
// When the cache and datacenter services migrate later, each gets its own
// small file like this one (cache_store.go, datacenter_store.go), wrapping
// the same pathWriter with their own paths. This file never changes.
//
// NOTE: fix the two internal import paths (ivaaws, logging) for your module.

import (
	"context"
	"errors"
	"fmt"
	"strings"

	"github.com/aws/aws-sdk-go-v2/config"
	"github.com/aws/aws-sdk-go-v2/feature/dynamodb/attributevalue"
	"github.com/aws/aws-sdk-go-v2/service/dynamodb"
	"go.uber.org/zap"

	// TODO: fix these import paths for your module
	"your.module/internal/ivaaws"
	"your.module/internal/logging"
)

// EntityStore - function-field style, like DatacenterAssignmentStorageService,
// so it can be stubbed in tests.
type EntityStore struct {
	// SetEntity writes entities.<flow>.<entityName> = value.
	SetEntity func(ctx context.Context, contactId ivaaws.ContactId, flow string, entityName string, value EntityValue) error

	// GetEntity reads one entity back.
	// found=false with nil error: contact, flow, or entity doesn't exist.
	GetEntity func(ctx context.Context, contactId ivaaws.ContactId, flow string, entityName string) (value EntityValue, found bool, err error)

	// GetEntities reads all of entities.<flow> as map[entityName]EntityValue.
	GetEntities func(ctx context.Context, contactId ivaaws.ContactId, flow string) (values map[string]EntityValue, found bool, err error)
}

// NewEntityStore - production constructor.
func NewEntityStore(tableName ivaaws.DynamoDBTableName) EntityStore {
	cfg, err := config.LoadDefaultConfig(context.Background())
	if err != nil {
		logging.Logger.Error("Failed to load AWS config for entity store", zap.Error(err))
		panic(err)
	}

	return newEntityStore(dynamodb.NewFromConfig(cfg), tableName)
}

// newEntityStore - testable constructor (inject a fake DynamoDBAPI).
func newEntityStore(
	dynamoClient DynamoDBAPI,
	tableName ivaaws.DynamoDBTableName,
) EntityStore {
	w := newPathWriter(dynamoClient, string(tableName))

	return EntityStore{

		SetEntity: func(ctx context.Context, contactId ivaaws.ContactId, flow string, entityName string, value EntityValue) error {
			// Validate inputs before touching DynamoDB (mirrors how
			// HTTPRequestExecutor validates the request up front).
			if err := validateEntityInput(contactId, flow, entityName, &value); err != nil {
				logging.Logger.Error("[ENTITY] Validation failed", zap.Error(err))
				return err
			}

			path := []string{entitiesAttribute, flow, entityName}

			// struct -> DynamoDB Map (driven by the dynamodbav tags)
			av, err := attributevalue.Marshal(value)
			if err != nil {
				return fmt.Errorf("failed to marshal entity value: %w", err)
			}

			if err := w.set(ctx, contactId.String(), path, av); err != nil {
				logging.Logger.Warn(
					"[ENTITY] Failed to store entity",
					zap.Error(err),
					zap.String("flow", flow),
					zap.String("entity", entityName),
				)
				return err
			}

			logging.Logger.Debug("[ENTITY] Stored entity", zap.String("path", strings.Join(path, ".")))
			return nil
		},

		GetEntity: func(ctx context.Context, contactId ivaaws.ContactId, flow string, entityName string) (EntityValue, bool, error) {
			var value EntityValue
			found, err := w.get(ctx, contactId.String(), []string{entitiesAttribute, flow, entityName}, &value)
			return value, found, err
		},

		GetEntities: func(ctx context.Context, contactId ivaaws.ContactId, flow string) (map[string]EntityValue, bool, error) {
			values := map[string]EntityValue{}
			found, err := w.get(ctx, contactId.String(), []string{entitiesAttribute, flow}, &values)
			return values, found, err
		},
	}
}

// validateEntityInput - domain validation for entity writes, applied before
// any DynamoDB call. Reads don't need it: bad inputs simply return found=false.
func validateEntityInput(
	contactId ivaaws.ContactId,
	flow string,
	entityName string,
	value *EntityValue,
) error {
	if strings.TrimSpace(contactId.String()) == "" {
		return errors.New("contactId must not be empty")
	}

	if strings.TrimSpace(flow) == "" {
		return errors.New("flow must not be empty")
	}

	if strings.TrimSpace(entityName) == "" {
		return errors.New("entityName must not be empty")
	}

	if strings.TrimSpace(value.Value) == "" {
		return fmt.Errorf("entity value must not be empty for %s.%s", flow, entityName)
	}

	// DynamoDB limit: expression attribute name values must be < 255 chars.
	if len(flow) > 255 || len(entityName) > 255 {
		return errors.New("flow and entityName must be under 255 characters")
	}

	return nil
}
