// buildExtractionPrompt substitutes the entity catalog and today's date into the
// prompt template, and composes the user message with the intent and dialogue.
func buildExtractionPrompt(tmpl string, entityDefs []entityDefinition, conversation, enterpriseIntent string) (string, string, error) {
	catalogJSON, err := buildCatalogJSON(entityDefs)
	if err != nil {
		return "", "", err
	}

	replacer := strings.NewReplacer(
		"{entity_catalog_json}", catalogJSON,
		"{today}", time.Now().Format("2006-01-02"),
	)
	systemPrompt := replacer.Replace(tmpl)
	userMessage := fmt.Sprintf("INTENT: %s\n\nCONVERSATION:\n%s", enterpriseIntent, conversation)
	return systemPrompt, userMessage, nil
}

// buildCatalogJSON serializes the entity definitions into the JSON catalog
// format expected by the prompt.
func buildCatalogJSON(entityDefs []entityDefinition) (string, error) {
	catalog := make([]catalogEntry, 0, len(entityDefs))
	for _, e := range entityDefs {
		entry := catalogEntry{
			Name:        e.EntityName,
			Description: e.EntityDescription,
			Utterances:  e.ExampleUtterances,
		}
		if len(e.AllowedValues) > 0 {
			entry.AllowedValues = e.AllowedValues
		}
		catalog = append(catalog, entry)
	}

	b, err := json.Marshal(catalog)
	if err != nil {
		return "", fmt.Errorf("failed to marshal entity catalog: %w", err)
	}
	return string(b), nil
}
