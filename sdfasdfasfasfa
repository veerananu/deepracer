// app is the single global instance of dependencies, initialized in init().
var app dependencies

func init() {
	cfg := appConfig{
		EntityDefTable:      envOrDefault("ENTITY_DEF_TABLE", "IntentEntityDefinitions"),
		CollectionTable:     envOrDefault("COLLECTION_TABLE", "ConversationContext"),
		ModelID:             envOrDefault("MODEL_ID", "us.amazon.nova-pro-v1:0"),
		ConfidenceThreshold: envFloatOrDefault("CONFIDENCE_THRESHOLD", 0.80),
		BedrockRegion:       envOrDefault("BEDROCK_REGION", "us-west-2"),
	}

	executablePath, pathErr := os.Executable()
	if pathErr != nil {
		executablePath = os.Args[0]
	}
	cfg.PromptFile = filepath.Join(filepath.Dir(executablePath), "extraction_prompt.txt")

	promptBytes, err := os.ReadFile(cfg.PromptFile)
	if err != nil {
		log.Printf("ERROR: prompt file not found/readable at %s: %v", cfg.PromptFile, err)
	} else {
		cfg.PromptTemplate = string(promptBytes)
		log.Printf("Loaded prompt from %s (%d chars)", cfg.PromptFile, len(cfg.PromptTemplate))
	}

	awsCfg, err := config.LoadDefaultConfig(context.Background())
	if err != nil {
		log.Fatalf("failed to load AWS config: %v", err)
	}

	bedrockCfg := awsCfg
	bedrockCfg.Region = cfg.BedrockRegion

	app = dependencies{
		dynamo:  dynamodb.NewFromConfig(awsCfg),
		bedrock: bedrockruntime.NewFromConfig(bedrockCfg),
		cfg:     cfg,
	}
}
