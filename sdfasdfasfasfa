	"errors"
	"time"

	"github.com/aws/aws-sdk-go-v2/aws"
	"github.com/aws/aws-sdk-go-v2/service/bedrockruntime"
	bedrocktypes "github.com/aws/aws-sdk-go-v2/service/bedrockruntime/types"
)

// callBedrock sends the system prompt and user message to the configured
// Bedrock model and returns the raw text response.
func callBedrock(parent context.Context, systemPrompt, userMessage string) (string, error) {
	ctx, cancel := context.WithTimeout(parent, 15*time.Second)
	defer cancel()

	out, err := app.bedrock.Converse(ctx, &bedrockruntime.ConverseInput{
		ModelId: aws.String(app.cfg.ModelID),
		System: []bedrocktypes.SystemContentBlock{
			&bedrocktypes.SystemContentBlockMemberText{Value: systemPrompt},
		},
		Messages: []bedrocktypes.Message{
			{
				Role: bedrocktypes.ConversationRoleUser,
				Content: []bedrocktypes.ContentBlock{
					&bedrocktypes.ContentBlockMemberText{Value: userMessage},
				},
			},
		},
		InferenceConfig: &bedrocktypes.InferenceConfiguration{
			MaxTokens:   aws.Int32(1024),
			Temperature: aws.Float32(0),
			TopP:        aws.Float32(0.9),
		},
	})
	if err != nil {
		return "", err
	}

	messageOutput, ok := out.Output.(*bedrocktypes.ConverseOutputMemberMessage)
	if !ok {
		return "", errors.New("bedrock response does not contain a message output")
	}
	if len(messageOutput.Value.Content) == 0 {
		return "", errors.New("empty bedrock response")
	}

	for _, block := range messageOutput.Value.Content {
		if textBlock, ok := block.(*bedrocktypes.ContentBlockMemberText); ok {
			return textBlock.Value, nil
		}
	}

	return "", errors.New("no text content found in bedrock response")
}
