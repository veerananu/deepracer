// endTriggers are the trigger values that mark the end of a conversation segment.
var endTriggers = map[string]struct{}{
	"transfer":     {},
	"self_service": {},
	"info":         {},
}

// extractTranscript fetches the conversation from DynamoDB and returns the last
// complete segment formatted as a User/Assistant dialogue string.
func extractTranscript(ctx context.Context, contactID string) (string, error) {
	out, err := app.dynamo.GetItem(ctx, &dynamodb.GetItemInput{
		TableName: aws.String(app.cfg.CollectionTable),
		Key: map[string]dynamodbtypes.AttributeValue{
			"ContactId": &dynamodbtypes.AttributeValueMemberS{Value: contactID},
			"Typing":    &dynamodbtypes.AttributeValueMemberS{Value: "ConversationContext"},
		},
	})
	if err != nil {
		return "", err
	}
	if len(out.Item) == 0 {
		return "", nil
	}

	var item collectionItem
	if err := attributevalue.UnmarshalMap(out.Item, &item); err != nil {
		return "", fmt.Errorf("failed to unmarshal CollectionConfig item: %w", err)
	}

	lastSegment := extractLastSegment(item.ConversationTurns)
	if len(lastSegment) == 0 {
		return "", nil
	}

	return formatDialogue(lastSegment), nil
}

// extractLastSegment walks the turns and returns the turns belonging to the last
// complete segment (ending on an end trigger).
func extractLastSegment(turns []conversationTurn) []conversationTurn {
	var lastSegment []conversationTurn
	current := make([]conversationTurn, 0, len(turns))

	for _, turn := range turns {
		current = append(current, turn)
		if _, isEnd := endTriggers[strings.ToLower(strings.TrimSpace(turn.Trigger))]; isEnd {
			lastSegment = make([]conversationTurn, len(current))
			copy(lastSegment, current)
			current = current[:0]
		}
	}

	return lastSegment
}

// formatDialogue converts a slice of turns into a User/Assistant dialogue string.
func formatDialogue(turns []conversationTurn) string {
	var b strings.Builder
	for _, turn := range turns {
		if userInput := strings.TrimSpace(turn.UserInput); userInput != "" {
			b.WriteString(fmt.Sprintf("User: \"%s\"\n", userInput))
		}
		if botResponse := strings.TrimSpace(turn.BotResponse); botResponse != "" {
			b.WriteString(fmt.Sprintf("Assistant: \"%s\"\n", botResponse))
		}
	}
	return strings.TrimSpace(b.String())
}
