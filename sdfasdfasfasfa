)

type entityOutput struct {
	Name        string  `json:"name"`
	Value       *string `json:"value"`
	Description string  `json:"description"`
}

// buildConnectResponse converts validated extractions into the flat string map
// returned to Amazon Connect.
func buildConnectResponse(valid validatedResult, entityDefs []entityDefinition, modelID string) map[string]string {
	entitiesList := make([]entityOutput, 0, len(entityDefs))

	for _, def := range entityDefs {
		name := def.EntityName
		ext := valid.Extracted[name]
		entry := entityOutput{
			Name:        name,
			Description: def.EntityDescription,
		}
		if ext != nil && ext.Value != nil {
			s := fmt.Sprintf("%v", ext.Value)
			entry.Value = &s
		}
		entitiesList = append(entitiesList, entry)
	}

	b, err := json.Marshal(entitiesList)
	entitiesStr := "[]"
	if err == nil {
		entitiesStr = string(b)
	}

	foundCount := 0
	missingCount := 0
	for _, entry := range entitiesList {
		if entry.Value == nil {
			missingCount++
		} else {
			foundCount++
		}
	}

	log.Printf("EXTRACTION COUNTS | total=%d found=%d missing=%d", len(entitiesList), foundCount, missingCount)

	// extraction_complete is "false" only when every value is null (nothing was extracted).
	extractionComplete := "true"
	if foundCount == 0 {
		extractionComplete = "false"
	}

	return map[string]string{
		"entities":            entitiesStr,
		"extraction_complete": extractionComplete,
	}
}

// handleError classifies an error into a known reason code and returns a safe
// Connect-compatible error response. AWS SDK typed errors are checked first;
// string matching is used only as a fallback.
func handleError(err error) (map[string]string, error) {
	reason := "INTERNAL_ERROR"

	// Check for HTTP response errors (timeout, throttle, auth).
	var httpErr *http.ResponseError
	if errors.As(err, &httpErr) {
		switch httpErr.HTTPStatusCode() {
		case 403:
			reason = "PERMISSION_DENIED"
		case 404:
			reason = "TABLE_NOT_FOUND"
		case 429:
			reason = "RATE_LIMITED"
		}
	}

	// Check for Smithy API errors (error codes from AWS services).
	var apiErr smithy.APIError
	if errors.As(err, &apiErr) {
		switch apiErr.ErrorCode() {
		case "AccessDeniedException", "UnauthorizedException":
			reason = "PERMISSION_DENIED"
		case "ThrottlingException", "RequestLimitExceeded":
			reason = "RATE_LIMITED"
		case "ResourceNotFoundException":
			reason = "TABLE_NOT_FOUND"
		}
	}

	// Fallback: context deadline exceeded = timeout.
	if reason == "INTERNAL_ERROR" {
		msg := strings.ToLower(err.Error())
		switch {
		case strings.Contains(msg, "context deadline exceeded"), strings.Contains(msg, "timed out"):
			reason = "BEDROCK_TIMEOUT"
		case strings.Contains(msg, "prompt template not loaded"):
			reason = "PROMPT_FILE_MISSING"
		}
	}

	log.Printf("ERROR | reason=%s msg=%s", reason, truncate(err.Error(), 300))
	resp := errorResponse(reason, truncate(err.Error(), 200))
	return resp, nil
}

// errorResponse builds a standard error payload for Connect.
func errorResponse(reasonCode, message string) map[string]string {
	return map[string]string{
		"status":              "ERROR",
		"reason_code":         reasonCode,
		"error_message":       message,
		"extraction_complete": "false",
		"entities":            "[]",
	}
}

// printResponse logs the response map as pretty-printed JSON.
func printResponse(response map[string]string) {
	b, err := json.MarshalIndent(response, "", "  ")
	if err != nil {
		log.Printf("[WARN] could not pretty-print response: %v | raw=%v", err, response)
		return
	}
	log.Printf("FINAL RESPONSE TO CONNECT:\n%s", string(b))
}
