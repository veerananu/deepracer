```go
package main

import (
	"fmt"
	"log"
	"regexp"
	"strconv"
	"strings"
	"time"
)

// nonDigit matches any character that is not a decimal digit.
var nonDigit = regexp.MustCompile(`\D`)

// validateExtractions checks each extracted entity against its definition rules
// and the confidence threshold, returning found and missing entity lists.
func validateExtractions(extracted map[string]extraction, entityDefs []entityDefinition, threshold float64) validatedResult {
	result := validatedResult{
		Extracted: make(map[string]*extraction, len(entityDefs)),
		Missing:   make([]string, 0),
	}

	for _, def := range entityDefs {
		name := def.EntityName
		ext, ok := extracted[name]
		if !ok || ext.Value == nil {
			result.Missing = append(result.Missing, name)
			result.Extracted[name] = nil
			continue
		}

		if strings.EqualFold(def.EntityType, "CONSTRAINED") {
			if !isAllowedValue(ext.Value, def.AllowedValues) {
				log.Printf("VALIDATE | %s rejected: value %q not in allowed list", name, ext.Value)
				result.Missing = append(result.Missing, name)
				result.Extracted[name] = nil
				continue
			}
		}

		if strings.EqualFold(def.EntityType, "OPEN") {
			if !validateOpenEntity(def, ext.Value) {
				log.Printf("VALIDATE | %s rejected: value %q failed rule %q", name, ext.Value, def.ValidationRuleType)
				result.Missing = append(result.Missing, name)
				result.Extracted[name] = nil
				continue
			}
		}

		if ext.Confidence < threshold {
			log.Printf("VALIDATE | %s rejected: confidence %.2f below threshold %.2f", name, ext.Confidence, threshold)
			result.Missing = append(result.Missing, name)
			result.Extracted[name] = nil
			continue
		}

		copyExt := ext
		result.Extracted[name] = &copyExt
	}

	return result
}

// isAllowedValue checks whether value matches any entry in the allowed list
// using case-insensitive trimmed comparison.
func isAllowedValue(value any, allowed []string) bool {
	normalized := strings.ToLower(strings.TrimSpace(fmt.Sprintf("%v", value)))
	for _, candidate := range allowed {
		if normalized == strings.ToLower(strings.TrimSpace(candidate)) {
			return true
		}
	}
	return false
}

// validateOpenEntity applies format validation based on the ValidationRuleType
// field stored in DynamoDB. If ValidationRuleType is empty or "FREE_TEXT",
// any non-null value is accepted.
func validateOpenEntity(def entityDefinition, value any) bool {
	valueStr := strings.TrimSpace(fmt.Sprintf("%v", value))
	if valueStr == "" {
		return false
	}

	switch strings.ToUpper(def.ValidationRuleType) {

	case "AMOUNT":
		cleaned := strings.ReplaceAll(strings.ReplaceAll(valueStr, ",", ""), "$", "")
		val, err := strconv.ParseFloat(cleaned, 64)
		if err != nil || val <= 0 || val > 10_000_000 {
			return false
		}

	case "DATE":
		if matched, _ := regexp.MatchString(`^\d{4}-\d{2}-\d{2}$`, valueStr); !matched {
			return false
		}

	case "PHONE":
		digits := nonDigit.ReplaceAllString(valueStr, "")
		if len(digits) != 10 && len(digits) != 11 {
			return false
		}

	case "DIGITS_4":
		if matched, _ := regexp.MatchString(`^\d{4}$`, valueStr); !matched {
			return false
		}

	case "DIGITS_9":
		if matched, _ := regexp.MatchString(`^\d{9}$`, valueStr); !matched {
			return false
		}

	case "DIGITS_4_17":
		digits := nonDigit.ReplaceAllString(valueStr, "")
		if len(digits) < 4 || len(digits) > 17 {
			return false
		}

	case "PERCENTAGE":
		val, err := strconv.ParseFloat(valueStr, 64)
		if err != nil || val < 0 || val > 100 {
			return false
		}

	case "YEAR":
		val, err := strconv.Atoi(valueStr)
		if err != nil || val <= 1990 || val > time.Now().Year()+1 {
			return false
		}

	case "FREE_TEXT", "":
		// no format check — any non-empty value passes

	default:
		log.Printf("VALIDATE | %s has unknown validationRuleType %q — treating as FREE_TEXT", def.EntityName, def.ValidationRuleType)
	}

	return true
}
