	"strings"
)

// parseLLMResponse strips any markdown fences from the LLM output and attempts
// to decode it into an entity extraction map.
func parseLLMResponse(llmResponse string) map[string]extraction {
	cleaned := strings.TrimSpace(llmResponse)
	cleaned = regexp.MustCompile(`^`+"```"+`(?:json)?\s*`).ReplaceAllString(cleaned, "")
	cleaned = regexp.MustCompile(`\s*`+"```"+`$`).ReplaceAllString(cleaned, "")

	if entities, ok := parseEntitiesFromJSON(cleaned); ok {
		return entities
	}

	// Fall back: find the outermost JSON object if response has extra text.
	if match := regexp.MustCompile(`(?s)\{.*\}`).FindString(cleaned); match != "" {
		if entities, ok := parseEntitiesFromJSON(match); ok {
			return entities
		}
	}

	log.Printf("Failed to parse LLM response: %.500s", llmResponse)
	return map[string]extraction{}
}

// parseEntitiesFromJSON unmarshals a raw JSON string into the extraction map.
func parseEntitiesFromJSON(raw string) (map[string]extraction, bool) {
	var parsed struct {
		Entities map[string]extraction `json:"entities"`
	}
	if err := json.Unmarshal([]byte(raw), &parsed); err != nil {
		return nil, false
	}
	if parsed.Entities == nil {
		return map[string]extraction{}, true
	}
	return parsed.Entities, true
}
